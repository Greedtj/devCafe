generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MenuMaster {
  id          String   @id @db.VarChar(100)
  category    String   @default("other") @db.VarChar(80)
  name        String   @db.VarChar(200)
  description String?  @db.VarChar(1000)
  basePrice   Decimal  @default(0) @db.Decimal(10, 2)
  enabled     Boolean  @default(true)
  fields      String?  @db.VarChar(500)
  imageUrl    String?  @db.VarChar(1000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("dev_cafe_menu")
}

model OptionMaster {
  groupId   String   @db.VarChar(100)
  value     String   @db.VarChar(100)
  label     String   @db.VarChar(200)
  price     Decimal  @default(0) @db.Decimal(10, 2)
  sortOrder Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([groupId, value])
  @@map("dev_cafe_options")
}

model Order {
  orderId       String      @id @db.VarChar(40)
  createdAt     DateTime    @default(now())
  userId        String      @db.VarChar(120)
  displayName   String?     @db.VarChar(200)
  total         Decimal     @default(0) @db.Decimal(10, 2)
  status        String      @default("pending-payment") @db.VarChar(60)
  paymentStatus String      @default("unpaid") @db.VarChar(60)
  lineMessageId String?     @db.VarChar(120)
  note          String?     @db.VarChar(1000)
  items         OrderItem[]

  @@index([userId, createdAt])
  @@map("dev_cafe_orders")
}

model OrderItem {
  id            Int      @id @default(autoincrement())
  orderId       String   @db.VarChar(40)
  lineNo        Int
  productId     String   @db.VarChar(100)
  productName   String   @db.VarChar(200)
  qty           Int      @default(1)
  unitPrice     Decimal  @default(0) @db.Decimal(10, 2)
  lineTotal     Decimal  @default(0) @db.Decimal(10, 2)
  optionSummary String?  @db.VarChar(1000)
  note          String?  @db.VarChar(1000)
  rawOptions    String?  @db.Text
  createdAt     DateTime @default(now())
  order         Order    @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId])
  @@map("dev_cafe_order_items")
}

model Customer {
  userId      String   @id @db.VarChar(120)
  displayName String?  @db.VarChar(200)
  pictureUrl  String?  @db.VarChar(1000)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@map("dev_cafe_customers")
}

model Setting {
  key       String   @id @db.VarChar(120)
  value     String?  @db.Text
  updatedAt DateTime @updatedAt

  @@map("dev_cafe_settings")
}
